PORT=3000
# SQLite хранится файлом на диске ВМ с API.
# Путь может быть абсолютным или относительным к каталогу server/.
SQLITE_PATH=./data/recordsbl.sqlite
# Object Storage (S3-совместимый API). Пример Cloud.ru: https://s3.cloud.ru
S3_ENDPOINT=https://s3.cloud.ru
S3_REGION=ru-central1
S3_BUCKET=your-bucket
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Public base URL for completed objects (optional, for events)
S3_PUBLIC_BASE=
